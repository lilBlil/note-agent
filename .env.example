# =========================
# LLM Provider API Keys
# Fill only the provider you want to use
# =========================

DEEPSEEK_API_KEY=your_deepseek_api_key
OPENAI_API_KEY=your_openai_api_key
DASHSCOPE_API_KEY=your_qwen_api_key
MOONSHOT_API_KEY=your_moonshot_api_key
ZHIPU_API_KEY=your_zhipu_api_key
SILICONFLOW_API_KEY=your_siliconflow_api_key


# =========================
# Search Backend
# Options: duckduckgo, tavily, perplexity, searxng
# =========================

SEARCH_API=duckduckgo

TAVILY_API_KEY=your_tavily_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key
SEARXNG_URL=http://localhost:8888


# =========================
# Default Runtime Settings
# =========================

DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_MAX_ITERATIONS=1


SEMANTIC_SCHOLAR_API_KEY=


# =========================
# Notion Integration
# 1. Create a Notion integration at https://www.notion.so/my-integrations
# 2. Copy the "Internal Integration Secret" → NOTION_API_KEY
# 3. In Notion, create or open a page that will hold all notes as sub-pages
# 4. Open that page in browser, copy the 32-char ID from the URL:
#    https://www.notion.so/workspace/Page-Name-<PAGE_ID>
#    PAGE_ID is a 32-char hex string (with dashes)
# 5. At the integration page, click "Add connections" on that parent page
# =========================

NOTION_API_KEY=your_notion_integration_secret
NOTION_PARENT_PAGE_ID=your_notion_parent_page_id
