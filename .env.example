# =========================
# Runtime defaults
# =========================

DEFAULT_LLM_PROVIDER=deepseek
DEFAULT_MAX_ITERATIONS=2
SEARCH_API=duckduckgo


# =========================
# Single-provider LLM mode
# Fill these when you only use DEFAULT_LLM_PROVIDER.
# =========================

LLM_API_KEY=your_provider_api_key
LLM_MODEL=
LLM_BASE_URL=


# =========================
# Optional provider-specific overrides
# These take priority over LLM_API_KEY for their provider.
# =========================

DEEPSEEK_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
SILICONFLOW_API_KEY=

DEEPSEEK_MODEL=deepseek-chat
OPENAI_MODEL=gpt-4o-mini
QWEN_MODEL=qwen-plus
MOONSHOT_MODEL=moonshot-v1-8k
ZHIPU_MODEL=glm-4-flash
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

DEEPSEEK_BASE_URL=
OPENAI_BASE_URL=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1


# =========================
# Search backends
# Options: duckduckgo, tavily, perplexity, searxng
# =========================

TAVILY_API_KEY=
PERPLEXITY_API_KEY=
SEARXNG_URL=http://localhost:8888
SEMANTIC_SCHOLAR_API_KEY=


# =========================
# Local runtime paths
# Relative paths are resolved from the project root.
# =========================

NOTES_DIR=notes
RUNS_DIR=runs
REFERENCE_CACHE_DIR=.cache/references
INTERMEDIATE_DIR=
ASSETS_DIR=


# =========================
# Generated note assets
# Options: formula, code, mermaid, chart
# =========================

ENABLED_ASSET_TYPES=formula,code,mermaid,chart
